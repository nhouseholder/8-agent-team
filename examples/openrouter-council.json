{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "OpenRouter-ready config — provider configured for optional OpenRouter use, but agents still inherit the active orchestrator/session model unless you add explicit overrides.",
  "model": "opencode-go/qwen3.6-plus",
  "plugin": [
    "oh-my-opencode-slim",
    "micode"
  ],
  "mcp": {
    "brain-router": {
      "type": "local",
      "command": [
        "brain-router"
      ],
      "environment": {
        "BRAIN_PROJECT": "global",
        "ENGRAM_DB": "{env:HOME}/.engram/engram.db",
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": [
        "engram",
        "mcp"
      ],
      "enabled": true
    },
    "mempalace": {
      "type": "local",
      "command": [
        "mempalace-mcp"
      ],
      "environment": {
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "prompt_file": "agents/orchestrator.md"
    },
    "strategist": {
      "mode": "all",
      "prompt_file": "agents/strategist.md"
    },
    "researcher": {
      "mode": "all",
      "prompt_file": "agents/researcher.md"
    },
    "designer": {
      "mode": "all",
      "prompt_file": "agents/designer.md"
    },
    "auditor": {
      "mode": "all",
      "prompt_file": "agents/auditor.md"
    },
    "council": {
      "mode": "all",
      "prompt_file": "agents/council.md",
      "note": "Provider is configured for OpenRouter, but councillors still inherit the active orchestrator/session model unless you add explicit agent-level overrides."
    },
    "generalist": {
      "mode": "all",
      "prompt_file": "agents/generalist.md"
    }
  },
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "YOUR_OPENROUTER_KEY"
      }
    }
  }
}
