{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "With-memory config — 8-agent system + MCP memory systems for persistent cross-session context.",
  "version": "1.6.0",
  "model": "opencode/kimi-k2.6",
  "mcp": {
    "brain-router": {
      "type": "local",
      "command": [
        "brain-router"
      ],
      "environment": {
        "BRAIN_PROJECT": "global",
        "ENGRAM_DB": "{env:HOME}/.engram/engram.db",
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": [
        "engram",
        "mcp"
      ],
      "enabled": true
    },
    "mempalace": {
      "type": "local",
      "command": [
        "mempalace-mcp"
      ],
      "environment": {
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "prompt_file": "agents/orchestrator.md"
    },
    "strategist": {
      "mode": "all",
      "prompt_file": "agents/strategist.md"
    },
    "researcher": {
      "mode": "all",
      "prompt_file": "agents/researcher.md"
    },
    "designer": {
      "mode": "all",
      "prompt_file": "agents/designer.md"
    },
    "auditor": {
      "mode": "all",
      "prompt_file": "agents/auditor.md"
    },
    "council": {
      "mode": "all",
      "prompt_file": "agents/council.md"
    },
    "generalist": {
      "mode": "all",
      "prompt_file": "agents/generalist.md"
    }
  }
}
