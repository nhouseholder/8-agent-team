{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "Enterprise config \u2014 full 10-agent system + memory + health monitoring + validation. All features enabled.",
  "version": "1.2.0",
  "model": "opencode-go/qwen3.6-plus",
  "mcp": {
    "brain-router": {
      "type": "local",
      "command": [
        "brain-router"
      ],
      "environment": {
        "BRAIN_PROJECT": "global",
        "ENGRAM_DB": "{env:HOME}/.engram/engram.db",
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": [
        "engram",
        "mcp"
      ],
      "enabled": true
    },
    "mempalace": {
      "type": "local",
      "command": [
        "mempalace-mcp"
      ],
      "environment": {
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/orchestrator.md"
    },
    "strategist": {
      "mode": "all",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/strategist.md"
    },
    "researcher": {
      "mode": "all",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/researcher.md"
    },
    "designer": {
      "mode": "all",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/designer.md"
    },
    "auditor": {
      "mode": "all",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/auditor.md"
    },
    "council": {
      "mode": "all",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/council.md"
    },
    "generalist": {
      "mode": "all",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/generalist.md"
    },
    "refiner": {
      "mode": "all",
      "model": "opencode-go/qwen3.6-plus",
      "prompt_file": "agents/refiner.md"
    }
  },
  "models": {
    "default": "opencode-go/qwen3.6-plus",
    "fast": "opencode-go/qwen3.6-plus",
    "smart": "opencode-go/qwen3.6-plus",
    "creative": "opencode-go/qwen3.6-plus"
  },
  "hooks": {
    "post_agent": {
      "command": [
        "node",
        "scripts/health-log.js"
      ],
      "description": "Log agent execution health after each run"
    },
    "pre_commit": {
      "command": [
        "node",
        "scripts/validate-agents.js"
      ],
      "description": "Validate all agent prompts before committing changes"
    }
  }
}
