{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/kimi-k2.6",
  "mcp": {
    "brain-router": {
      "type": "local",
      "command": [
        "brain-router"
      ],
      "environment": {
        "BRAIN_PROJECT": "global",
        "ENGRAM_DB": "{env:HOME}/.engram/engram.db",
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    },
    "engram": {
      "type": "local",
      "command": [
        "engram",
        "mcp"
      ],
      "enabled": true
    },
    "mempalace": {
      "type": "local",
      "command": [
        "mempalace-mcp"
      ],
      "environment": {
        "MEMPALACE_PALACE": "{env:HOME}/.mempalace/global"
      },
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "prompt_file": "agents/orchestrator.md"
    },
    "explorer": {
      "mode": "all",
      "prompt_file": "agents/explorer.md"
    },
    "strategist": {
      "mode": "all",
      "prompt_file": "agents/strategist.md"
    },
    "researcher": {
      "mode": "all",
      "prompt_file": "agents/researcher.md"
    },
    "designer": {
      "mode": "all",
      "prompt_file": "agents/designer.md"
    },
    "auditor": {
      "mode": "all",
      "prompt_file": "agents/auditor.md"
    },
    "council": {
      "mode": "subagent",
      "prompt_file": "agents/council.md",
      "note": "Protocol reference only. Orchestrator fans out to 3 councillor agents below."
    },
    "council-advocate-for": {
      "mode": "subagent",
      "model": "openrouter/openai/gpt-oss-120b:free",
      "prompt_file": "agents/council-advocate-for.md"
    },
    "council-advocate-against": {
      "mode": "subagent",
      "model": "openrouter/xiaomi/mimo-v2-flash:free",
      "prompt_file": "agents/council-advocate-against.md"
    },
    "council-judge": {
      "mode": "subagent",
      "model": "openrouter/qwen/qwen3-235b-a22b-thinking-2507:free",
      "prompt_file": "agents/council-judge.md"
    },
    "generalist": {
      "mode": "all",
      "prompt_file": "agents/generalist.md"
    }
  },
  "permission": {
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  },
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "YOUR_OPENROUTER_KEY"
      }
    }
  },
  "models": {
    "default": "opencode/kimi-k2.6",
    "fast": "opencode/kimi-k2.6",
    "smart": "opencode/kimi-k2.6",
    "creative": "opencode/kimi-k2.6",
    "council-advocate-for": "openrouter/openai/gpt-oss-120b:free",
    "council-advocate-against": "openrouter/xiaomi/mimo-v2-flash:free",
    "council-judge": "openrouter/qwen/qwen3-235b-a22b-thinking-2507:free"
  }
}
