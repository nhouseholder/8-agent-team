{
  // Active preset
  "preset": "default",

  // Top-level presets (agent model overrides per preset)
  "presets": {
    "default": {
      "councillor_1": {},
      "councillor_2": {},
      "councillor_3": {}
    }
  },

  // Council configuration follows the active session model unless you add overrides
  "council": {
    "master": {}
  },

  // Disable observer by default (only enable if you need vision analysis)
  "disabled_agents": ["observer"],

  // Todo continuation settings
  "todoContinuation": {
    "maxContinuations": 5,
    "cooldownMs": 3000,
    "autoEnable": false,
    "autoEnableThreshold": 4
  }
}
